{
  "manifest_version": 3,
  "name": "X Downloader - 本地视频下载",
  "version": "0.3.0",
  "description": "在 X/Twitter 页面内检测视频并私密地下载到本地。",
  "permissions": [
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://*.x.com/*",
    "https://twitter.com/*",
    "https://*.twitter.com/*",
    "https://video.twimg.com/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "X Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://mobile.x.com/*",
        "https://pro.x.com/*",
        "https://twitter.com/*",
        "https://mobile.twitter.com/*",
        "https://pro.twitter.com/*"
      ],
      "exclude_matches": [
        "https://x.com/i/cards-frame/*",
        "https://*.x.com/i/cards-frame/*",
        "https://twitter.com/i/cards-frame/*",
        "https://*.twitter.com/i/cards-frame/*"
      ],
      "js": [
        "src/tray-core.js",
        "src/content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://x.com/*",
        "https://mobile.x.com/*",
        "https://pro.x.com/*",
        "https://twitter.com/*",
        "https://mobile.twitter.com/*",
        "https://pro.twitter.com/*"
      ],
      "exclude_matches": [
        "https://x.com/i/cards-frame/*",
        "https://*.x.com/i/cards-frame/*",
        "https://twitter.com/i/cards-frame/*",
        "https://*.twitter.com/i/cards-frame/*"
      ],
      "js": [
        "src/hls-core.js",
        "src/page-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
